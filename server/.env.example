# 复制本文件为 .env 后填写（.env 不要提交 Git）

PORT=8787
GMAIL_USER=summerriverfall@gmail.com
# Gmail「应用专用密码」16 位（可带空格，服务端会去掉）
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# —— Google Calendar OAuth（与发信可同一 Google 账号，须有日历编辑权限）——
# 在 Google Cloud Console 创建「桌面应用」OAuth 客户端后填写：
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 运行 npm run auth-google 后粘贴：
GOOGLE_REFRESH_TOKEN=

# 可选：前端请求时带上 Header: x-api-key
# API_KEY=change-me

# 可选：限制来源，逗号分隔；* 表示不限制
ALLOWED_ORIGINS=*
